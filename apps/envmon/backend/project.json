{
  "name": "envmon-backend",
  "projectType": "application",
  "tags": ["scope:envmon", "type:backend"],
  "implicitDependencies": ["shared-db"],
  "targets": {
    "sync": {
      "executor": "nx:run-commands",
      "options": {
        "command": "uv sync --package envmon-backend",
        "cwd": "{workspaceRoot}"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "PYTHONPATH=. uv run --no-sync --package envmon-backend uvicorn backend.main:app --reload --port 8001",
        "cwd": "apps/envmon"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "PYTHONPATH=apps/envmon:libs/shared-db/src:libs/shared-api/src uv run --no-sync --package envmon-backend python -m pytest apps/envmon/backend/tests",
        "cwd": "{workspaceRoot}"
      },
      "inputs": ["pyFiles", "sharedGlobals"],
      "cache": true
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "PYTHONPATH=apps/envmon:libs/shared-db/src:libs/shared-api/src uv run --no-sync ruff check apps/envmon/backend",
        "cwd": "{workspaceRoot}"
      },
      "inputs": ["pyFiles", "sharedGlobals"],
      "cache": true
    },
    "deploy": {
      "executor": "nx:run-commands",
      "options": {
        "command": "make deploy PROFILE=prod TARGET=prod",
        "cwd": "apps/envmon"
      }
    }
  }
}
