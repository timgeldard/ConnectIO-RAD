{
  "name": "envmon-backend",
  "projectType": "application",
  "tags": ["scope:envmon", "type:backend"],
  "implicitDependencies": ["shared-db", "shared-api", "shared-geo"],
  "targets": {
    "sync": {
      "executor": "nx:run-commands",
      "options": {
        "command": "uv sync --package envmon-backend",
        "cwd": "{workspaceRoot}"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "uv run --no-sync --package envmon-backend uvicorn envmon_backend.main:app --reload --port 8001",
        "cwd": "{workspaceRoot}"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "uv run --no-sync --package envmon-backend python -m pytest apps/envmon/backend/tests",
        "cwd": "{workspaceRoot}"
      },
      "inputs": ["pyFiles", "^pyFiles", "sharedGlobals"],
      "cache": true
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "uv run --no-sync ruff check apps/envmon/backend",
        "cwd": "{workspaceRoot}"
      },
      "inputs": ["pyFiles", "^pyFiles", "sharedGlobals"],
      "cache": true
    },
    "deploy": {
      "executor": "nx:run-commands",
      "options": {
        "command": "make deploy PROFILE=prod TARGET=prod",
        "cwd": "apps/envmon"
      },
      "configurations": {
        "uat": {
          "command": "make deploy PROFILE=uat TARGET=uat"
        },
        "prod": {
          "command": "make deploy PROFILE=prod TARGET=prod"
        }
      }
    }
  }
}
