{
  "name": "envmon-frontend",
  "projectType": "application",
  "tags": ["scope:envmon", "type:frontend"],
  "targets": {
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vite",
        "cwd": "apps/envmon/frontend"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run build",
        "cwd": "apps/envmon/frontend"
      },
      "inputs": ["tsFiles", "^tsFiles", "sharedGlobals"],
      "cache": true
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run typecheck",
        "cwd": "apps/envmon/frontend"
      }
    }
  }
}
