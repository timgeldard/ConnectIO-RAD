{
  "name": "platform",
  "projectType": "application",
  "tags": [
    "scope:platform"
  ],
  "implicitDependencies": [
    "platform-frontend",
    "platform-backend",
    "connectedquality-frontend",
    "processorderhistory-frontend",
    "warehouse360-frontend",
    "spc-frontend",
    "trace2-frontend",
    "envmon-frontend",
    "shared-reporting",
    "shared-ui"
  ],
  "targets": {
    "platform-build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "python3 scripts/build.py",
        "cwd": "apps/platform"
      },
      "inputs": [
        "{workspaceRoot}/apps/platform/scripts/**/*",
        "{workspaceRoot}/apps/platform/deploy.toml",
        "{workspaceRoot}/apps/platform/app.template.yaml",
        "{workspaceRoot}/apps/platform/databricks.yml",
        "{workspaceRoot}/apps/platform/backend/pyproject.toml",
        "{workspaceRoot}/apps/platform/requirements*.txt",
        "{workspaceRoot}/apps/*/deploy.toml",
        "{workspaceRoot}/apps/*/app.template.yaml",
        "{workspaceRoot}/apps/*/databricks.yml",
        "{workspaceRoot}/apps/*/backend/pyproject.toml",
        "{workspaceRoot}/apps/*/frontend/package.json",
        "{workspaceRoot}/apps/*/frontend/package-lock.json",
        "{workspaceRoot}/apps/*/frontend/src/**/*",
        "{workspaceRoot}/libs/shared-*/src/**/*",
        "{workspaceRoot}/libs/shared-*/pyproject.toml",
        "{workspaceRoot}/apps/*/backend/**/*"
      ],
      "cache": true
    },
    "deploy": {
      "executor": "nx:run-commands",
      "options": {
        "command": "python3 ../../scripts/deploy_app.py --app-dir . --profile prod --target prod",
        "cwd": "apps/platform"
      },
      "dependsOn": ["platform-build"],
      "cache": false
    }
  }
}
