{
  "name": "processorderhistory-e2e",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/processorderhistory/e2e/tests",
  "tags": ["scope:poh", "type:e2e"],
  "implicitDependencies": ["processorderhistory-frontend", "processorderhistory-backend"],
  "targets": {
    "e2e": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx playwright test --config=apps/processorderhistory/e2e/playwright.config.ts",
        "cwd": "{workspaceRoot}"
      }
    },
    "e2e-ci": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx playwright test --config=apps/processorderhistory/e2e/playwright.config.ts --reporter=blob",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}
