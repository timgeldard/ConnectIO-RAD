{
  "name": "spc-e2e",
  "projectType": "application",
  "tags": ["scope:spc", "type:e2e"],
  "implicitDependencies": ["spc-frontend", "spc-backend"],
  "targets": {
    "e2e": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx playwright test --config=apps/spc/e2e/playwright.config.ts",
        "cwd": "{workspaceRoot}"
      }
    },
    "e2e-ci": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx playwright test --config=apps/spc/e2e/playwright.config.ts --reporter=blob",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}
