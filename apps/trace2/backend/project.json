{
  "name": "trace2-backend",
  "projectType": "application",
  "tags": ["scope:trace2", "type:backend"],
  "implicitDependencies": ["shared-db"],
  "targets": {
    "sync": {
      "executor": "nx:run-commands",
      "options": {
        "command": "uv sync --package trace2-backend",
        "cwd": "{workspaceRoot}"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "PYTHONPATH=. uv run --package trace2-backend uvicorn backend.main:app --reload --port 8002",
        "cwd": "apps/trace2"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "PYTHONPATH=. uv run --package trace2-backend pytest backend/tests",
        "cwd": "apps/trace2"
      },
      "inputs": ["pyFiles", "sharedGlobals"],
      "cache": true
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "PYTHONPATH=. uv run ruff check backend && PYTHONPATH=. uv run mypy backend",
        "cwd": "apps/trace2"
      },
      "inputs": ["pyFiles", "sharedGlobals"],
      "cache": true
    },
    "deploy": {
      "executor": "nx:run-commands",
      "options": {
        "command": "databricks bundle deploy --target prod",
        "cwd": "apps/trace2"
      }
    }
  }
}
