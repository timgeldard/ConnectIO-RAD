{
  "name": "trace2-e2e",
  "projectType": "application",
  "tags": ["scope:trace2", "type:e2e"],
  "implicitDependencies": ["trace2-frontend", "trace2-backend"],
  "targets": {
    "e2e": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx playwright test --config=apps/trace2/e2e/playwright.config.ts",
        "cwd": "{workspaceRoot}"
      }
    },
    "e2e-ci": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx playwright test --config=apps/trace2/e2e/playwright.config.ts --reporter=blob",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}
