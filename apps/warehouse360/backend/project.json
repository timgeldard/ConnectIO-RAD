{
  "name": "warehouse360-backend",
  "projectType": "application",
  "tags": ["scope:warehouse360", "type:backend"],
  "targets": {
    "sync": {
      "executor": "nx:run-commands",
      "options": {
        "command": "uv sync --package warehouse360-backend",
        "cwd": "{workspaceRoot}"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "PYTHONPATH=apps/warehouse360 uv run --no-sync --package warehouse360-backend python -m pytest apps/warehouse360/backend/tests",
        "cwd": "{workspaceRoot}"
      },
      "inputs": ["pyFiles", "^pyFiles", "sharedGlobals"],
      "cache": true
    }
  }
}
