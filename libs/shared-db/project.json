{
  "name": "shared-db",
  "projectType": "library",
  "tags": ["scope:shared", "type:lib"],
  "targets": {
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "uv run --no-sync ruff check .",
        "cwd": "libs/shared-db"
      },
      "inputs": ["pyFiles", "sharedGlobals"],
      "cache": true
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "uv run --no-sync mypy src",
        "cwd": "libs/shared-db"
      },
      "inputs": ["pyFiles", "^pyFiles", "sharedGlobals"],
      "cache": true
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "PYTHONPATH=libs/shared-db/src uv run --no-sync --package shared-db python -m pytest libs/shared-db/tests",
        "cwd": "{workspaceRoot}"
      },
      "inputs": ["pyFiles", "sharedGlobals"],
      "cache": true
    }
  }
}
