{
  "name": "shared-ddd",
  "projectType": "library",
  "tags": [
    "scope:shared",
    "type:backend"
  ],
  "targets": {
    "sync": {
      "executor": "nx:run-commands",
      "options": {
        "command": "uv sync --package shared-ddd",
        "cwd": "{workspaceRoot}"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "PYTHONPATH=libs/shared-ddd/src uv run --no-sync --package shared-ddd python -m pytest libs/shared-ddd/tests",
        "cwd": "{workspaceRoot}"
      },
      "inputs": [
        "pyFiles",
        "sharedGlobals"
      ]
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "uv run --no-sync ruff check .",
        "cwd": "libs/shared-ddd"
      },
      "inputs": [
        "pyFiles",
        "sharedGlobals"
      ],
      "cache": true
    }
  }
}
