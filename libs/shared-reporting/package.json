    "zustand": "^5.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.12",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "^5.6.3",
    "vitest": "^4.1.5"
