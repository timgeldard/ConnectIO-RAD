{
  "name": "shared-reporting",
  "projectType": "library",
  "tags": ["scope:shared", "type:frontend"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run build",
        "cwd": "libs/shared-reporting"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run test:ci",
        "cwd": "libs/shared-reporting"
      }
    },
    "test:coverage": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run test:coverage",
        "cwd": "libs/shared-reporting"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run lint",
        "cwd": "libs/shared-reporting"
      }
    }
  }
}
