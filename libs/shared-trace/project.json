{
  "name": "shared-trace",
  "projectType": "library",
  "tags": ["scope:shared", "type:backend"],
  "targets": {
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "uv run --no-sync ruff check .",
        "cwd": "libs/shared-trace"
      },
      "inputs": ["pyFiles", "sharedGlobals"],
      "cache": true
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "PYTHONPATH=libs/shared-trace/src uv run --no-sync --package shared-trace python -m pytest libs/shared-trace/tests",
        "cwd": "{workspaceRoot}"
      },
      "inputs": ["pyFiles", "sharedGlobals"],
      "cache": true
    }
  }
}
