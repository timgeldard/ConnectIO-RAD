{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "namedInputs": {
    "pyFiles": [
      "{projectRoot}/**/*.py",
      "{projectRoot}/pyproject.toml",
      "{workspaceRoot}/uv.lock"
    ],
    "tsFiles": [
      "{projectRoot}/src/**/*.{ts,tsx}",
      "{projectRoot}/vite.config.ts",
      "{projectRoot}/vite.config.js",
      "{projectRoot}/package.json"
    ],
    "sharedGlobals": [
      "{workspaceRoot}/nx.json"
    ]
  },
  "targetDefaults": {
    "sync": {
      "cache": false
    },
    "lint": {
      "cache": true,
      "executor": "nx:run-commands",
      "options": {
        "command": "uv run --no-sync ruff check {projectRoot}",
        "cwd": "{workspaceRoot}"
      },
      "inputs": [
        "pyFiles",
        "^pyFiles",
        "sharedGlobals"
      ]
    },
    "test": {
      "cache": true,
      "executor": "nx:run-commands",
      "options": {
        "command": "uv run --no-sync python -m pytest",
        "cwd": "{projectRoot}"
      },
      "inputs": [
        "pyFiles",
        "^pyFiles",
        "sharedGlobals"
      ],
      "dependsOn": [
        "^test"
      ]
    },
    "build": {
      "cache": true,
      "inputs": [
        "tsFiles",
        "^tsFiles",
        "sharedGlobals"
      ],
      "dependsOn": [
        "^build"
      ]
    },
    "deploy": {
      "cache": false,
      "dependsOn": [
        "build"
      ]
    },
    "e2e": {
      "cache": false,
      "inputs": [
        "tsFiles",
        "^tsFiles",
        "sharedGlobals"
      ]
    },
    "e2e-ci": {
      "cache": false,
      "inputs": [
        "tsFiles",
        "^tsFiles",
        "sharedGlobals"
      ]
    }
  },
  "analytics": false,
  "pluginsConfig": {
    "@nx/eslint": {
      "depConstraints": [
        {
          "sourceTag": "scope:spc",
          "onlyDependOnLibsWithTags": [
            "scope:spc",
            "scope:shared"
          ]
        },
        {
          "sourceTag": "scope:warehouse360",
          "onlyDependOnLibsWithTags": [
            "scope:warehouse360",
            "scope:shared"
          ]
        },
        {
          "sourceTag": "scope:processorderhistory",
          "onlyDependOnLibsWithTags": [
            "scope:processorderhistory",
            "scope:shared"
          ]
        },
        {
          "sourceTag": "scope:trace2",
          "onlyDependOnLibsWithTags": [
            "scope:trace2",
            "scope:shared"
          ]
        },
        {
          "sourceTag": "scope:envmon",
          "onlyDependOnLibsWithTags": [
            "scope:envmon",
            "scope:shared"
          ]
        },
        {
          "sourceTag": "scope:connectedquality",
          "onlyDependOnLibsWithTags": [
            "scope:connectedquality",
            "scope:shared",
            "scope:spc",
            "scope:trace2",
            "scope:envmon"
          ]
        },
        {
          "sourceTag": "scope:platform",
          "onlyDependOnLibsWithTags": [
            "scope:platform",
            "scope:shared",
            "scope:connectedquality",
            "scope:processorderhistory",
            "scope:warehouse360"
          ]
        },
        {
          "sourceTag": "type:frontend",
          "notDependOnLibsWithTags": [
            "type:backend"
          ]
        },
        {
          "sourceTag": "scope:shared",
          "onlyDependOnLibsWithTags": [
            "scope:shared"
          ]
        },
        {
          "sourceTag": "scope:template",
          "onlyDependOnLibsWithTags": [
            "scope:template",
            "scope:shared"
          ]
        }
      ]
    }
  }
}
