{
  "name": "connectio-rad",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*/frontend",
    "libs/shared-frontend-api",
    "libs/shared-frontend-i18n",
    "libs/shared-ui"
  ],
  "scripts": {
    "dev:spc": "nx run spc-frontend:dev",
    "dev:envmon": "nx run envmon-frontend:dev",
    "dev:trace2": "nx run trace2-frontend:dev",
    "dev:processorderhistory": "nx run processorderhistory-frontend:dev",
    "build": "nx run-many -t build",
    "lint": "nx run-many -t lint",
    "test": "nx run-many -t test",
    "typecheck": "nx run-many -t typecheck",
    "check:repo": "python3 scripts/validate_repo_contract.py && python3 scripts/validate_i18n.py",
    "check:i18n": "python3 scripts/validate_i18n.py",
    "audit:i18n": "python3 scripts/audit_i18n_literals.py",
    "render:app-configs": "python3 scripts/render_app_configs.py",
    "check:app-configs": "python3 scripts/validate_app_configs.py",
    "graph": "nx graph"
  },
  "devDependencies": {
    "@nx/js": "^22.0.0",
    "@nx/vite": "^22.0.0",
    "nx": "^22.0.0",
    "typescript": "~5.5.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-darwin-arm64": "^4.60.2",
    "@rollup/rollup-win32-x64-msvc": "^4.60.2"
  },
  "dependencies": {
    "esbuild": "^0.21.5"
  }
}
